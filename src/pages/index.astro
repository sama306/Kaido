---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/react/Hero.tsx";
import Historia from "../components/react/Historia.tsx";
import Especialidades from "../components/react/Especialidades.tsx";
import Espacio from "../components/react/Espacio.tsx";
import Menu from "../components/react/Menu.tsx";
---

<Layout>
  <main>
    <Hero client:load />

    <Historia client:load />

    <Especialidades client:load />

    <Espacio client:load />

    <Menu client:visible />

    <!-- Eventos -->
    <section id="eventos" class="min-h-screen flex items-center justify-center bg-crema px-6">
      <div class="max-w-2xl text-center">
        <h2 class="text-h2 text-verde-oscuro">Eventos</h2>
      </div>
    </section>

    <!-- Ubicación -->
    <section id="ubicacion" class="min-h-screen flex items-center justify-center bg-crema px-6">
      <div class="max-w-2xl text-center">
        <h2 class="text-h2 text-verde-oscuro">Ubicación</h2>
      </div>
    </section>
  </main>
</Layout>
