---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main>
    <!-- Hero -->
    <section id="hero" class="min-h-screen flex items-center justify-center bg-crema pt-20">
      <div class="text-center px-6">
        <h1 class="text-display text-verde-oscuro">Kaidō</h1>
        <p class="text-body text-texto-muted mt-4 max-w-lg mx-auto">Café de especialidad en el corazón de Palermo</p>
      </div>
    </section>

    <!-- Historia -->
    <section id="historia" class="min-h-screen flex items-center justify-center bg-crema px-6">
      <div class="max-w-2xl text-center">
        <h2 class="text-h2 text-verde-oscuro">Nuestra Historia</h2>
      </div>
    </section>

    <!-- Especialidades -->
    <section id="especialidades" class="min-h-screen flex items-center justify-center bg-crema px-6">
      <div class="max-w-2xl text-center">
        <h2 class="text-h2 text-verde-oscuro">Especialidades</h2>
      </div>
    </section>

    <!-- Espacio -->
    <section id="espacio" class="min-h-screen flex items-center justify-center bg-crema px-6">
      <div class="max-w-2xl text-center">
        <h2 class="text-h2 text-verde-oscuro">Nuestro Espacio</h2>
      </div>
    </section>

    <!-- Menú -->
    <section id="menu" class="min-h-screen flex items-center justify-center bg-crema px-6">
      <div class="max-w-2xl text-center">
        <h2 class="text-h2 text-verde-oscuro">Menú</h2>
      </div>
    </section>

    <!-- Eventos -->
    <section id="eventos" class="min-h-screen flex items-center justify-center bg-crema px-6">
      <div class="max-w-2xl text-center">
        <h2 class="text-h2 text-verde-oscuro">Eventos</h2>
      </div>
    </section>

    <!-- Ubicación -->
    <section id="ubicacion" class="min-h-screen flex items-center justify-center bg-crema px-6">
      <div class="max-w-2xl text-center">
        <h2 class="text-h2 text-verde-oscuro">Ubicación</h2>
      </div>
    </section>
  </main>
</Layout>
